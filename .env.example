# =============================================================================
# Turnstile solver
#   yescaptcha  - remote createTask-compatible service (default)
#   ezsolver    - local ismoiloffS/EzSolver HTTP service
# Auto-detect if TURNSTILE_SOLVER is empty:
#   YESCAPTCHA_API_KEY set  -> yescaptcha
#   EZSOLVER_ENDPOINT set   -> ezsolver
# =============================================================================
TURNSTILE_SOLVER=yescaptcha

# --- YesCaptcha (when TURNSTILE_SOLVER=yescaptcha) ---
YESCAPTCHA_API_KEY=
# YESCAPTCHA_ENDPOINT=https://api.yescaptcha.com
# YESCAPTCHA_ENDPOINT=https://cn.yescaptcha.com

# --- EzSolver (when TURNSTILE_SOLVER=ezsolver) ---
# Start first:  python service.py   (from https://github.com/ismoiloffS/EzSolver)
EZSOLVER_ENDPOINT=http://127.0.0.1:8191
EZSOLVER_TIMEOUT=120

# =============================================================================
# Email backend
# =============================================================================
# Required when using default email backend (-e tempmail)
TEMPMAIL_API_KEY=

# Optional - Cloudflare D1 alias mailbox (-e cloudflare)
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_D1_DB_ID=
# Comma-separated domains you control (must match your D1 mail schema)
ALIAS_MAIL_DOMAINS=mail.example.com
# ALIAS_EXTRA_DOMAINS=

# =============================================================================
# Optional outputs / proxy
# =============================================================================
# CLIPROXYAPI_AUTH_DIR=/path/to/CLIProxyAPI/data/auth
# HTTPS_PROXY=http://127.0.0.1:7890
# HTTP_PROXY=http://127.0.0.1:7890
